# Token bot lấy từ https://discord.com/developers/applications (Tab Bot > Reset Token)
# ⚠️ KHÔNG commit token thật. Nếu lỡ lộ token, vào Portal bấm Reset Token ngay.
DISCORD_TOKEN=dan-token-bot-cua-ban-vao-day

# Client ID (Application ID) của bot — Tab General Information
CLIENT_ID=dan-application-id-vao-day

# ID server (guild) để đăng ký lệnh cho nhanh (chuột phải server > Copy Server ID)
GUILD_ID=dan-server-id-vao-day

# --- (TÙY CHỌN) ĐƯỜNG DẪN DATABASE ---
# Mặc định db nằm ở tu-tien.db cạnh code. Nếu deploy bằng cách UPLOAD TAY cả thư mục,
# hãy đặt DB_PATH trỏ tới 1 thư mục mà bạn KHÔNG upload đè (vd thư mục data/ riêng)
# để KHÔNG mất dữ liệu người chơi + panel mỗi lần cập nhật code.
# Ví dụ trên host:  DB_PATH=/home/container/data/tu-tien.db
# DB_PATH=

# --- KÊNH PANEL (bật Developer Mode > chuột phải kênh > Copy Channel ID) ---
# Sau khi điền, chạy /setup (admin) để bot đăng panel cố định vào từng kênh.
CH_SO_NHAP=id-kenh-so-nhap-giang-ho
CH_NHIEM_VU=id-kenh-nhiem-vu
CH_MON_PHAI=id-kenh-mon-phai-cua-ban
CH_HO_SO=id-kenh-ho-so-nhan-vat
CH_BANG_XEP_HANG=id-kenh-bang-xep-hang
# Vọng Âm Đài — kênh nhận MỌI thông báo game (độ kiếp, hạ boss, kỳ tích). Không cần /setup.
CH_VONG_AM_DAI=id-kenh-vong-am-dai
# Tu Luyện Trường — panel tu hành (vận công/bế quan/voice) + luyện đan.
CH_TU_LUYEN=id-kenh-tu-luyen
# (GĐ16: KHÔNG còn dùng — Đột Phá đã gộp vào panel Tu Luyện. Có thể bỏ trống/xóa kênh này.)
# CH_DOT_PHA=id-kenh-dot-pha
# Luyện Trường — bí cảnh + các khu farm.
CH_LUYEN_TRUONG=id-kenh-luyen-truong
# Đấu Pháp Đài — Luận Võ Đài tỉ thí xếp hạng (PvP, mở ở Nguyên Anh).
CH_DAU_DAI=id-kenh-dau-phap-dai
# (GĐ18 BỎ kênh Trang Bị + Đột Phá — truy cập qua panel Hồ Sơ / Tu Luyện. Không cần CH_TRANG_BI / CH_DOT_PHA.)
# Boss Thế Giới — công phạt chung toàn server, chia thưởng theo sát thương (mở ở Kim Đan).
CH_BOSS_THE_GIOI=id-kenh-boss-the-gioi
# Phó Bản Tổ Đội — co-op 2-4 người đánh boss HP chung, rớt trang bị cố định + Tiên Ngọc (mở ở Kim Đan).
CH_TO_DOI=id-kenh-pho-ban-to-doi
# Phường Thị — shop bán vật phẩm tiêu hao (nguyên liệu, hạt giống, Tinh Thiết, đan) + Phường Thị Cao Cấp (Tiên Ngọc).
CH_SHOP=id-kenh-phuong-thi

# Lò Rèn — rèn/cường hóa/nâng bậc trang bị (mở ở Kim Đan).
CH_LO_REN=id-kenh-lo-ren

# Bãi Săn Yêu — săn yêu nhanh, có panel sticky (mở ở Luyện Khí). Để trống nếu chưa tách kênh riêng.
CH_SAN_YEU=id-kenh-bai-san-yeu

# (Tùy chọn) Role được phép chạy /setup. Bỏ trống = ai có quyền Manage Guild đều chạy được.
ADMIN_ROLE_ID=

# (Tùy chọn) Role cấp cho người chơi khi NHẬP ĐẠO lần đầu (để @nhận thông báo game).
# Bỏ trống = bot TỰ TẠO role tên "Đạo Hữu" (cần bot có quyền Manage Roles).
PLAYER_ROLE_ID=
